{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TerranSoul",
  "version": "0.1.0",
  "identifier": "com.terranes.terransoul",
  "build": {
    "beforeDevCommand": "npm run dev:vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TerranSoul",
        "width": 420,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": true,
        "backgroundColor": [0, 0, 0, 0],
        "alwaysOnTop": false,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico", "icons/icon.icns"],
    "resources": {
      "../docs": "docs",
      "../instructions": "instructions"
    }
  }
}
