# TerranSoul MCP Mode — Containerized Brain Server
#
# Builds the Rust release binary and runs it with
# --mcp-tray so AI coding agents can connect on port 7423.
#
# Usage:
#   docker compose -f docker-compose.mcp.yml up --build
#   (or: npm run mcp)
#
# Persistent data lives in the `mcp-data` Docker volume.

# ─── Stage 1: Build frontend with Vite ────────────────────────────────────────
FROM node:22-slim AS frontend

WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci --ignore-scripts
COPY tsconfig.json tsconfig.node.json vite.config.ts index.html ./
COPY src/ src/
COPY public/ public/
RUN npx vite build

# ─── Stage 2: Build Rust release binary ───────────────────────────────────────
FROM rust:1.82-bookworm AS builder

# Install Tauri system deps (needed to compile, not to run headless)
RUN apt-get update && apt-get install -y --no-install-recommends \
    libwebkit2gtk-4.1-dev \
    libgtk-3-dev \
    libayatana-appindicator3-dev \
    librsvg2-dev \
    libssl-dev \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY src-tauri/ src-tauri/
COPY --from=frontend /app/dist/ dist/

WORKDIR /app/src-tauri
RUN cargo build --release --locked 2>/dev/null || cargo build --release

# ─── Stage 3: Slim runtime ────────────────────────────────────────────────────
FROM debian:bookworm-slim AS runtime

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    libssl3 \
    libwebkit2gtk-4.1-0 \
    libgtk-3-0 \
    libayatana-appindicator3-1 \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user for the server
RUN useradd -m -s /bin/bash terransoul
USER terransoul
WORKDIR /home/terransoul

# Copy the release binary
COPY --from=builder /app/src-tauri/target/release/terransoul ./terransoul

# Persistent data directory (mounted as Docker volume)
RUN mkdir -p /home/terransoul/mcp-data
VOLUME /home/terransoul/mcp-data

# MCP HTTP server port
EXPOSE 7423

# Environment
ENV TERRANSOUL_MCP_DATA_DIR=/home/terransoul/mcp-data
ENV RUST_LOG=info

# Run the headless MCP server
ENTRYPOINT ["./terransoul", "--mcp-tray"]
