{
  "name": "terransoul",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "node scripts/kill-dev-terransoul.mjs && npx tauri dev",
    "dev:desktop-e2e": "set WEBVIEW2_ADDITIONAL_BROWSER_ARGUMENTS=--remote-debugging-port=9222&& npm run dev",
    "dev:full": "node scripts/kill-dev-terransoul.mjs && cargo build --manifest-path src-tauri/Cargo.toml && npx tauri dev",
    "dev:vite": "node scripts/check-port.cjs && vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:real": "playwright test --config Real-E2E/playwright.config.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "tauri": "tauri",
    "brain:tokens": "node scripts/brain-tokens.mjs",
    "brain:longmem:prepare": "node scripts/longmemeval-s.mjs prepare",
    "brain:longmem:run": "node scripts/longmemeval-s.mjs run",
    "brain:longmem:sample": "node scripts/longmemeval-s.mjs sample",
    "brain:locomo:prepare": "node scripts/locomo-mteb.mjs prepare",
    "brain:locomo:run": "node scripts/locomo-mteb.mjs run",
    "brain:locomo:sample": "node scripts/locomo-mteb.mjs sample",
    "tauri:ios:check": "node scripts/tauri-ios-check.mjs",
    "tauri:ios:init": "node scripts/tauri-ios-check.mjs --init",
    "mcp": "node scripts/copilot-start-mcp.mjs 240",
    "mcp:setup": "cargo run --manifest-path src-tauri/Cargo.toml --quiet -- --mcp-setup",
    "mcp:app": "npx vite build && node scripts/run-target-mcp.mjs --mcp-app",
    "mcp:container": "docker compose -f docker-compose.mcp.yml up -d --build",
    "mcp:container:config": "docker compose -f docker-compose.mcp.yml config",
    "mcp:container:logs": "docker compose -f docker-compose.mcp.yml logs -f mcp",
    "mcp:container:rebuild": "docker compose -f docker-compose.mcp.yml build --no-cache mcp",
    "mcp:container:stop": "docker compose -f docker-compose.mcp.yml down",
    "mcp:sync-docs": "node scripts/sync-docs-to-mcp.mjs",
    "mcp:obsidian": "node scripts/mcp-obsidian.mjs"
  },
  "overrides": {
    "@protobufjs/utf8": "1.1.1"
  },
  "dependencies": {
    "@bufbuild/connect": "^0.13.0",
    "@bufbuild/connect-web": "^0.13.0",
    "@bufbuild/protobuf": "^1.10.1",
    "@mediapipe/tasks-vision": "^0.10.34",
    "@pixiv/three-vrm": "^3.4.0",
    "@pixiv/three-vrm-animation": "^3.5.2",
    "@primeuix/themes": "^1.2.5",
    "@ricky0123/vad-web": "^0.0.30",
    "@rollup/rollup-linux-x64-gnu": "^4.60.3",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-barcode-scanner": "^2.4.4",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-stronghold": "^2.3.1",
    "@types/cytoscape": "^3.21.9",
    "cytoscape": "^3.33.2",
    "d3-force-3d": "^3.0.6",
    "graphology": "^0.26.0",
    "pinia": "^2.3.1",
    "primevue": "^4.5.5",
    "sigma": "^3.0.3",
    "three": "^0.175.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/cli": "^2.11.0",
    "@types/three": "^0.183.1",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/test-utils": "^2.4.6",
    "better-sqlite3": "^12.9.0",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^9.33.0",
    "globals": "^15.15.0",
    "hyparquet": "^1.25.8",
    "jsdom": "^29.0.2",
    "pdfkit": "^0.18.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^6.4.2",
    "vitest": "^4.1.4",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.2.10"
  }
}
