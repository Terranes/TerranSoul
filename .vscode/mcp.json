{
  // TerranSoul MCP servers — connects VS Code Copilot to the brain.
  //
  // `terransoul-brain-mcp` is a lightweight stdio proxy. It does not start a
  // second brain process; it attaches to the first running TerranSoul MCP
  // server in priority order:
  //   1. release app on 127.0.0.1:7421
  //   2. MCP tray (`npm run mcp`) on 127.0.0.1:7423
  //   3. dev app on 127.0.0.1:7422
  //
  // The proxy reads the matching token file itself, so Copilot sessions do not
  // need bearer-token environment variables or a VS Code restart. The workspace
  // auto-start task still starts the tray when no release/tray/dev server is already
  // serving MCP. See `rules/agent-mcp-bootstrap.md`.

  "servers": {
    "terransoul-brain-mcp": {
      "type": "stdio",
      "command": "node",
      "args": [
        "${workspaceFolder}/scripts/mcp-tray-proxy.mjs"
      ],
      "env": {
        "TERRANSOUL_MCP_WORKSPACE": "${workspaceFolder}",
        "TERRANSOUL_MCP_PROXY_WAIT": "240"
      }
    },
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:TERRANSOUL_MCP_GITHUB_TOKEN}"
      }
    }
  }
}
